{
  "version": 2,
  "name": "the-daily-grind",
  "builds": [
    {
      "src": "dist/server.cjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "dist/server.cjs"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/dist/assets/$1"
    },
    {
      "src": "/(.*\\.(?:js|css|ico|png|jpg|jpeg|svg|webp|woff|woff2|ttf|eot|map))",
      "dest": "/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "dist/server.cjs"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
